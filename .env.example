# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SMTP Configuration for immediate Contact Form Email Notifications
# Specify these keys inside AI Studio secrets to enable real email delivery.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
EMAIL_TO=ogunakatochukwu@gmail.com,alelechi17@gmail.com

# PRODUCTION ENVIRONMENT MIGRATION (Neon PostgreSQL & External Storage)
# Database Connection String for Neon host
DATABASE_URL="postgresql://username:password@ep-host-xyz.region.pooler.neon.tech/neondb?sslmode=require"

# Permanent Image Storage configuration values (Cloudinary direct)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend API URL configuration
VITE_API_URL="https://tochukwu-portfolio-vwa2.onrender.com"

# Alternative External Image Storage configuration values (supporting both formats)
STORAGE_PROVIDER="cloudinary" # e.g. "cloudinary", "s3"
STORAGE_BUCKET_NAME=          # Maps to CLOUDINARY_CLOUD_NAME if provider is "cloudinary"
STORAGE_API_KEY=              # Maps to CLOUDINARY_API_KEY
STORAGE_API_SECRET=           # Maps to CLOUDINARY_API_SECRET
STORAGE_ENDPOINT_URL=
